---
import type { CultureLocale } from '../lib/culture';
const { locale = 'zh' } = Astro.props as { locale?: CultureLocale };
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); const lang = locale === 'en' ? '/en' : '';
const t = locale === 'zh' ? { title:'第一次进入黑城堡？', text:'这里是一座原创故事宇宙。你可以按自己的习惯选择入口。', story:'从推荐故事开始', map:'从四境地图开始', people:'从人物档案开始', close:'我自己探索' } : { title:'First time in the Dark Castle?', text:'This is an original story universe. Choose the entrance that matches the way you explore.', story:'Begin with a story', map:'Begin with the atlas', people:'Begin with characters', close:'Explore on my own' };
---
<dialog class="universe-guide" data-universe-guide aria-labelledby="guide-title"><button class="universe-guide-close" type="button" data-guide-close aria-label={t.close}>×</button><p>DARK CASTLE · ORIENTATION</p><h2 id="guide-title">{t.title}</h2><span>{t.text}</span><div><a href={`${base}${lang}/culture/stories/the-bell-that-never-saw-dawn`}>01 <b>{t.story}</b><small>STORY</small></a><a href="#atlas" data-guide-close>02 <b>{t.map}</b><small>ATLAS</small></a><a href={`${base}${lang}/culture#characters`}>03 <b>{t.people}</b><small>CHARACTERS</small></a></div><button class="universe-guide-enter" type="button" data-guide-close>{t.close} →</button></dialog>
<script>
  const guide = document.querySelector<HTMLDialogElement>('[data-universe-guide]');
  if (guide && !localStorage.getItem('dc-guide-seen')) window.setTimeout(() => guide.showModal(), 500);
  document.querySelectorAll('[data-guide-close]').forEach((item) => item.addEventListener('click', () => { localStorage.setItem('dc-guide-seen','1'); guide?.close(); }));
</script>
