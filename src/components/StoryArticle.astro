---
import type { UniverseStory } from '../lib/stories'; import { universeStories } from '../lib/stories';
import { findChamber, type CultureLocale } from '../lib/culture'; import { universeCharacters, portraitForCharacter } from '../lib/characters';
const { story, locale = 'zh' } = Astro.props as { story: UniverseStory; locale?: CultureLocale };
const base=import.meta.env.BASE_URL.replace(/\/$/,'');const lang=locale==='en'?'/en':'';const path=(value:string)=>`${base}${lang}${value}`;
const chamber=findChamber(story.chamber)!;const sections=locale==='zh'?story.sectionsZh:story.sectionsEn;const title=locale==='zh'?story.titleZh:story.titleEn;const dek=locale==='zh'?story.dekZh:story.dekEn;const quote=locale==='zh'?story.quoteZh:story.quoteEn;
const characters=universeCharacters.filter((person)=>person.storySlugs.includes(story.slug));const relatedStories=universeStories.filter((item)=>item.slug!==story.slug&&(item.chamber===story.chamber||item.featured)).slice(0,3);
const t=locale==='zh'?{back:'返回地区',contents:'章节',people:'出场人物',next:'继续探索',read:'阅读下一篇',smaller:'缩小字号',larger:'放大字号',mode:'切换阅读明暗',directory:'折叠目录',resume:'继续上次位置',remaining:'分钟剩余',end:'本篇已读完',world:'进入所属地区'}:{back:'Back to region',contents:'Chapters',people:'Characters',next:'Keep exploring',read:'Read next',smaller:'Smaller text',larger:'Larger text',mode:'Toggle reading mode',directory:'Toggle contents',resume:'Resume previous position',remaining:'min remaining',end:'Story complete',world:'Enter this region'};
---
<article class={`story-reader-v3 reader-${chamber.tone}`} data-story-reader>
  <div class="story-v3-progress"><span></span></div>
  <div class="reading-toolbar" aria-label={locale==='zh'?'阅读工具':'Reading tools'}><button type="button" data-font="-1" aria-label={t.smaller}>A−</button><button type="button" data-font="1" aria-label={t.larger}>A+</button><button type="button" data-reading-mode aria-label={t.mode}>◐</button><button type="button" data-toc-toggle aria-label={t.directory}>☰</button><span><b data-reading-remaining>{story.readTime}</b> {t.remaining}</span></div>
  <button class="reading-resume" type="button" data-reading-resume hidden>{t.resume} · <b data-resume-percent></b>% →</button>
  <header class="story-v3-hero"><img src={`${base}${story.image}`} alt="" /><div></div><a href={path(`/culture/${story.chamber}`)}>← {t.back}</a><section><p>{locale==='zh'?story.categoryZh:story.categoryEn} · {story.readTime} MIN · ORIGINAL FICTION</p><h1>{title}</h1><span>{dek}</span><small>{locale==='zh'?story.eraZh:story.eraEn}</small></section></header>
  <div class="story-v3-layout">
    <aside data-story-toc><p>{t.contents}</p>{sections.map((section,index)=><a href={`#chapter-${index+1}`} data-toc-link={index+1}><span>0{index+1}</span>{section.title}</a>)}<div><p>{t.people}</p>{characters.map((person)=><a class="toc-person" href="#characters"><span>{person.glyph}</span>{locale==='zh'?person.nameZh:person.nameEn}</a>)}</div></aside>
    <main><blockquote>“{quote}”</blockquote>{sections.map((section,index)=><section id={`chapter-${index+1}`} data-chapter={index+1}><small>CHAPTER 0{index+1}</small><h2>{section.title}</h2>{section.text.map((paragraph)=><p>{paragraph}</p>)}</section>)}<footer class="story-end-mark"><span>{chamber.glyph}</span><p>{t.end}</p><a href={path(`/culture/${story.chamber}`)}>{t.world} · {chamber[locale].name} →</a></footer></main>
  </div>
  <section class="story-character-cast" id="characters"><div class="dc-section-head"><div><p class="dc-kicker">CHARACTER CAST</p><h2>{t.people}</h2></div></div><div>{characters.map((person)=>{const portrait=portraitForCharacter(person.id,person.portrait);return <article>{portrait?<img src={`${base}${portrait}`} alt={locale==='zh'?`${person.nameZh}人物肖像`:`Portrait of ${person.nameEn}`} loading="lazy" decoding="async" />:<span>{person.glyph}</span>}<div><h3>{locale==='zh'?person.nameZh:person.nameEn}</h3><strong>{locale==='zh'?person.roleZh:person.roleEn}</strong><p>{locale==='zh'?person.bioZh:person.bioEn}</p><small>{locale==='zh'?person.appearanceZh:person.appearanceEn}</small></div></article>})}</div></section>
  <section class="story-v3-related"><div class="dc-section-head"><div><p class="dc-kicker">NEXT STORIES</p><h2>{t.next}</h2></div></div><div>{relatedStories.map((item)=><a href={path(`/culture/stories/${item.slug}`)}><img src={`${base}${item.image}`} alt="" loading="lazy" decoding="async" /><span>{locale==='zh'?item.categoryZh:item.categoryEn}</span><h3>{locale==='zh'?item.titleZh:item.titleEn}</h3><i>{t.read} →</i></a>)}</div></section>
</article>
<script is:inline define:vars={{ storyKey: story.slug, storyTitle: title }}>
  const reader=document.querySelector('[data-story-reader]');const bar=document.querySelector('.story-v3-progress span');const remaining=document.querySelector('[data-reading-remaining]');const resume=document.querySelector('[data-reading-resume]');const resumePercent=document.querySelector('[data-resume-percent]');const key=`dc-progress-${storyKey}`;let font=Number(localStorage.getItem('dc-reader-font')||0);let light=localStorage.getItem('dc-reader-mode')!=='dark';
  const apply=()=>{reader?.style.setProperty('--reader-scale',String(1+font*.08));reader?.classList.toggle('is-dark-reading',!light)};apply();
  document.querySelectorAll('[data-font]').forEach((button)=>button.addEventListener('click',()=>{font=Math.max(-2,Math.min(3,font+Number(button.dataset.font)));localStorage.setItem('dc-reader-font',String(font));apply()}));document.querySelector('[data-reading-mode]')?.addEventListener('click',()=>{light=!light;localStorage.setItem('dc-reader-mode',light?'light':'dark');apply()});document.querySelector('[data-toc-toggle]')?.addEventListener('click',()=>reader?.classList.toggle('toc-collapsed'));
  const saved=Number(localStorage.getItem(key)||0);if(saved>.06&&saved<.93&&resume&&resumePercent){resume.hidden=false;resumePercent.textContent=String(Math.round(saved*100));resume.addEventListener('click',()=>scrollTo({top:saved*(document.documentElement.scrollHeight-innerHeight),behavior:'smooth'}))}
  const progress=()=>{const max=document.documentElement.scrollHeight-innerHeight;const value=max>0?Math.min(1,scrollY/max):0;if(bar)bar.style.width=`${value*100}%`;localStorage.setItem(key,String(value));localStorage.setItem('dc-last-story',JSON.stringify({title:storyTitle,href:location.href,progress:value}));if(remaining)remaining.textContent=String(Math.max(1,Math.ceil((1-value)*Number(remaining.dataset.total||'9'))))};if(remaining)remaining.dataset.total=remaining.textContent||'9';addEventListener('scroll',progress,{passive:true});progress();
  const links=document.querySelectorAll('[data-toc-link]');const observer=new IntersectionObserver((entries)=>entries.forEach((entry)=>{if(entry.isIntersecting)links.forEach((link)=>link.classList.toggle('is-current',link.dataset.tocLink===entry.target.dataset.chapter))}),{rootMargin:'-20% 0px -65%'});document.querySelectorAll('[data-chapter]').forEach((chapter)=>observer.observe(chapter));
</script>
