---
import type { UniverseStory } from '../lib/stories'; import { universeStories } from '../lib/stories'; import { findChamber, type CultureLocale } from '../lib/culture'; import { products } from '../lib/products';
const { story, locale = 'zh' } = Astro.props as { story: UniverseStory; locale?: CultureLocale };
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); const lang = locale === 'en' ? '/en' : ''; const path = (v:string) => `${base}${lang}${v}`;
const chamber = findChamber(story.chamber)!; const sections = locale === 'zh' ? story.sectionsZh : story.sectionsEn; const title = locale === 'zh' ? story.titleZh : story.titleEn; const dek = locale === 'zh' ? story.dekZh : story.dekEn; const quote = locale === 'zh' ? story.quoteZh : story.quoteEn;
const characters = locale === 'zh' ? story.charactersZh : story.charactersEn; const relatedStories = universeStories.filter((item) => item.slug !== story.slug && (item.chamber === story.chamber || item.featured)).slice(0,3); const relatedProducts = story.productIds.map((sku) => products.find((p) => p.sku === sku)).filter(Boolean);
const t = locale === 'zh' ? { back:'返回地区', contents:'章节', people:'出场人物', next:'继续探索', relics:'故事中的遗物', read:'阅读下一篇' } : { back:'Back to region', contents:'Chapters', people:'Characters', next:'Keep exploring', relics:'Relics in this story', read:'Read next' };
---
<article class={`story-reader-v3 reader-${chamber.tone}`}>
  <div class="story-v3-progress"><span></span></div>
  <header class="story-v3-hero"><img src={`${base}${story.image}`} alt="" /><div></div><a href={path(`/culture/${story.chamber}`)}>← {t.back}</a><section><p>{locale === 'zh' ? story.categoryZh : story.categoryEn} · {story.readTime} MIN</p><h1>{title}</h1><span>{dek}</span><small>{locale === 'zh' ? story.eraZh : story.eraEn}</small></section></header>
  <div class="story-v3-layout">
    <aside><p>{t.contents}</p>{sections.map((section,index) => <a href={`#chapter-${index + 1}`}><span>0{index + 1}</span>{section.title}</a>)}<div><p>{t.people}</p>{characters.map((person) => <span>{person}</span>)}</div></aside>
    <main><blockquote>“{quote}”</blockquote>{sections.map((section,index) => <section id={`chapter-${index + 1}`}><small>CHAPTER 0{index + 1}</small><h2>{section.title}</h2>{section.text.map((paragraph) => <p>{paragraph}</p>)}</section>)}</main>
  </div>
  <section class="story-v3-related"><div class="dc-section-head"><div><p class="dc-kicker">NEXT STORIES</p><h2>{t.next}</h2></div></div><div>{relatedStories.map((item) => <a href={path(`/culture/stories/${item.slug}`)}><img src={`${base}${item.image}`} alt="" /><span>{locale === 'zh' ? item.categoryZh : item.categoryEn}</span><h3>{locale === 'zh' ? item.titleZh : item.titleEn}</h3><i>{t.read} →</i></a>)}</div></section>
  <section class="story-v3-relics"><div><p class="dc-kicker">OBJECTS IN THE WORLD</p><h2>{t.relics}</h2></div><div>{relatedProducts.map((product) => product && <a href={path(`/catalog#${product.category}`)}><img src={`${base}${product.image}`} alt="" /><span>{product.sku}</span><h3>{locale === 'zh' ? product.nameZh : product.nameEn}</h3></a>)}</div></section>
</article>
<script>const bar=document.querySelector<HTMLElement>('.story-v3-progress span');const progress=()=>{if(!bar)return;const max=document.documentElement.scrollHeight-innerHeight;bar.style.width=`${max>0?scrollY/max*100:0}%`};addEventListener('scroll',progress,{passive:true});progress();</script>
