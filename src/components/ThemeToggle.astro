---
const { label } = Astro.props;
---
<button class="theme-toggle" type="button" aria-label={label} title={label} data-theme-toggle>
  <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 3v2m0 14v2M3 12h2m14 0h2M5.64 5.64l1.42 1.42m9.88 9.88 1.42 1.42m0-12.8-1.42 1.42M7.06 16.94l-1.42 1.42M16 12a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z"/></svg>
</button>
<script is:inline>
  const root = document.documentElement;
  const toggle = document.querySelector('[data-theme-toggle]');
  const saved = localStorage.getItem('theme');
  if (saved) root.dataset.theme = saved;
  toggle?.addEventListener('click', () => {
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>
