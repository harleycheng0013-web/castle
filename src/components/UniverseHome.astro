---
import { chambers, universeEpoch, type CultureLocale } from '../lib/culture';
import { universeStories } from '../lib/stories';
import UniverseGuide from './UniverseGuide.astro';
const { locale = 'zh' } = Astro.props as { locale?: CultureLocale };
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); const lang = locale === 'en' ? '/en' : '';
const path = (value: string) => `${base}${lang}${value}`;
const heroStories = universeStories.filter((story) => story.featured).slice(0, 3);
const t = locale === 'zh' ? {
  universe:'DARK CASTLE 原创文化宇宙', explore:'探索地区', atlas:'四境星图',
  atlasText:'四条失落道路在黑城堡交汇。选择一个坐标，进入它的地点、人物与故事。', enter:'进入地区',
  latest:'最新故事', latestText:'所有故事发生于同一个世界，并通过人物、地点与暮辉纪 427 年的共同事件彼此连接。', allStories:'进入故事档案', read:'阅读故事',
  worlds:'四境档案', worldsText:'每个地区都有自己的法则、纪年、势力与冲突。',
  continue:'继续上次阅读', start:'选择你的入口', startText:'没有规定的阅读顺序。按你最习惯的方式进入。',
  next:'下一卷：黑城堡中央纪事', nextText:'第十三钟、白树花期、大熄灯与黑船归港发生在同一天。下一卷将让四条故事线第一次在黑城堡汇合。', notify:'查看暮辉纪年'
} : {
  universe:'THE ORIGINAL DARK CASTLE UNIVERSE', explore:'Explore region', atlas:'Atlas of Four Realms',
  atlasText:'Four lost roads meet at the Dark Castle. Choose a coordinate to enter its places, people, and stories.', enter:'Enter region',
  latest:'Latest stories', latestText:'Every story belongs to one world, connected by characters, places, and the shared events of Gloaming 427.', allStories:'Open story archive', read:'Read story',
  worlds:'Four realm archive', worldsText:'Each region has its own law, chronology, factions, and conflict.',
  continue:'Continue reading', start:'Choose your entrance', startText:'There is no required order. Enter in the way that fits you.',
  next:'Next volume: Chronicles of the Central Castle', nextText:'The thirteenth bell, ninth flowering, Great Extinguishing, and black ship occur on the same day. The next volume brings all four threads to the Dark Castle.', notify:'View the Gloaming chronology'
};
---
<div class="dc-home-v3">
  <UniverseGuide locale={locale} />
  <a class="dc-continue" data-continue-reading hidden href="#"><span>{t.continue}</span><b data-continue-title></b><i>→</i></a>

  <section class="dc-spotlight" aria-label={t.latest}>
    <div class="dc-spotlight-track">{heroStories.map((story, index) => <article class:list={['dc-slide', { 'is-active': index === 0 }]} data-slide={index}><img src={`${base}${story.image}`} alt="" decoding="async" /><div class="dc-slide-wash"></div><div class="dc-slide-content"><p class="dc-kicker">ORIGINAL FICTION · {locale === 'zh' ? story.categoryZh : story.categoryEn} · {story.readTime} MIN</p><h1>{locale === 'zh' ? story.titleZh : story.titleEn}</h1><p>{locale === 'zh' ? story.dekZh : story.dekEn}</p><div><a class="dc-gold-button" href={path(`/culture/stories/${story.slug}`)}>{t.read}</a><a href={path(`/culture/${story.chamber}`)}>{t.explore} →</a></div></div><div class="dc-slide-region">{chambers.find((c) => c.slug === story.chamber)?.[locale].name}</div></article>)}</div>
    <div class="dc-slider-controls"><button type="button" data-dir="-1" aria-label="Previous">←</button><span><b>01</b> / 0{heroStories.length}</span><button type="button" data-dir="1" aria-label="Next">→</button></div>
    <div class="dc-spotlight-caption"><span>{t.universe}</span><p>{universeEpoch[locale]}</p></div>
  </section>

  <section class="dc-start-paths"><div><p class="dc-kicker">START HERE</p><h2>{t.start}</h2><span>{t.startText}</span></div><div><a href={path('/culture/stories/the-bell-that-never-saw-dawn')}><b>01</b><span>{locale === 'zh' ? '从一篇故事开始' : 'Begin with a story'}</span><i>STORY →</i></a><a href="#atlas"><b>02</b><span>{locale === 'zh' ? '从四境地图开始' : 'Begin with the atlas'}</span><i>ATLAS ↓</i></a><a href={path('/culture#characters')}><b>03</b><span>{locale === 'zh' ? '从人物命运开始' : 'Begin with a character'}</span><i>PEOPLE →</i></a></div></section>

  <section class="dc-atlas" id="atlas"><img class="dc-atlas-bg" src={`${base}/images/dark-castle-atlas-v1.png`} alt="" loading="lazy" decoding="async" /><div class="dc-atlas-grid"></div><header><p class="dc-kicker">EXPLORE THE REALMS</p><h2>{t.atlas}</h2><p>{t.atlasText}</p></header><div class="dc-map"><div class="dc-map-orbit"></div>{chambers.map((chamber, index) => <a class:list={['dc-map-node', `node-${index + 1}`, { 'is-active': index === 0 }]} href={path(`/culture/${chamber.slug}`)} data-map-node={index} style={`--x:${chamber.position.x}%;--y:${chamber.position.y}%`} aria-label={`${chamber[locale].name}: ${chamber[locale].epithet}`}><i>{chamber.glyph}</i><span>{chamber[locale].name}</span><small>0{index + 1}</small></a>)}<div class="dc-map-card" aria-live="polite">{chambers.map((chamber, index) => <div class:list={{ 'is-active': index === 0 }} data-map-card={index}><p>REGION 0{index + 1} · 02 STORIES · 03 LANDMARKS</p><h3>{chamber[locale].name}</h3><strong>{chamber[locale].epithet}</strong><span>{chamber[locale].legend}</span><a href={path(`/culture/${chamber.slug}`)}>{t.enter} →</a></div>)}</div></div></section>

  <section class="dc-story-hub"><div class="dc-section-head"><div><p class="dc-kicker">FEATURED FICTION</p><h2>{t.latest}</h2></div><p>{t.latestText}</p><a href={path('/culture#stories')}>{t.allStories} →</a></div><div class="dc-story-mosaic">{universeStories.slice(0, 7).map((story, index) => <a class:list={['dc-story-tile', { 'is-main': index === 0 }]} href={path(`/culture/stories/${story.slug}`)}><img src={`${base}${story.image}`} alt="" loading={index < 2 ? 'eager' : 'lazy'} decoding="async" /><div><p>{locale === 'zh' ? story.categoryZh : story.categoryEn}</p><h3>{locale === 'zh' ? story.titleZh : story.titleEn}</h3><span>{story.readTime} MIN · {locale === 'zh' ? story.eraZh : story.eraEn}</span></div></a>)}</div></section>

  <section class="dc-realm-index"><div class="dc-section-head"><div><p class="dc-kicker">REGIONS</p><h2>{t.worlds}</h2></div><p>{t.worldsText}</p></div><div class="dc-realm-grid">{chambers.map((chamber) => <a href={path(`/culture/${chamber.slug}`)} class={`realm-${chamber.tone}`}><span>{chamber.glyph}</span><p>{chamber.number}</p><h3>{chamber[locale].name}</h3><strong>{chamber[locale].epithet}</strong><i>EXPLORE →</i></a>)}</div></section>

  <section class="dc-next-volume" id="chronology"><p class="dc-kicker">THE SAGA CONTINUES</p><h2>{t.next}</h2><p>{t.nextText}</p><a href={path('/culture#chronology')}>{t.notify} →</a></section>
</div>
<script>
  const slides=[...document.querySelectorAll<HTMLElement>('.dc-slide')];const count=document.querySelector<HTMLElement>('.dc-slider-controls b');let current=0;const reduced=matchMedia('(prefers-reduced-motion: reduce)').matches||document.documentElement.dataset.motion==='reduced';
  const show=(next:number)=>{current=(next+slides.length)%slides.length;slides.forEach((el,i)=>el.classList.toggle('is-active',i===current));if(count)count.textContent=`0${current+1}`};document.querySelectorAll<HTMLButtonElement>('.dc-slider-controls button').forEach((button)=>button.addEventListener('click',()=>show(current+Number(button.dataset.dir))));let timer=0;if(!reduced&&!matchMedia('(max-width: 680px)').matches)timer=window.setInterval(()=>show(current+1),6500);document.querySelector('.dc-spotlight')?.addEventListener('pointerenter',()=>clearInterval(timer));
  const activateMap=(index:number)=>{document.querySelectorAll<HTMLElement>('[data-map-node]').forEach((el,i)=>el.classList.toggle('is-active',i===index));document.querySelectorAll<HTMLElement>('[data-map-card]').forEach((el,i)=>el.classList.toggle('is-active',i===index))};document.querySelectorAll<HTMLElement>('[data-map-node]').forEach((node)=>{const index=Number(node.dataset.mapNode);node.addEventListener('pointerenter',()=>activateMap(index));node.addEventListener('focus',()=>activateMap(index))});
  const last=localStorage.getItem('dc-last-story');if(last){try{const data=JSON.parse(last);const link=document.querySelector<HTMLAnchorElement>('[data-continue-reading]');const title=document.querySelector('[data-continue-title]');if(link&&title&&data.href){link.href=data.href;title.textContent=data.title;link.hidden=false}}catch{}}
</script>
