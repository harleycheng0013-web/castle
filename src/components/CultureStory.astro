---
import type { CultureChamber, CultureLocale } from '../lib/culture';
import { products } from '../lib/products'; import { universeStories } from '../lib/stories';
const { chamber, locale = 'zh' } = Astro.props as { chamber: CultureChamber; locale?: CultureLocale };
const c = chamber[locale]; const base = import.meta.env.BASE_URL.replace(/\/$/, ''); const lang = locale === 'en' ? '/en' : '';
const path = (value:string) => `${base}${lang}${value}`; const stories = universeStories.filter((story) => story.chamber === chamber.slug); const related = chamber.productIds.map((sku) => products.find((p) => p.sku === sku)).filter(Boolean);
const t = locale === 'zh' ? { back:'返回文化宇宙', stories:'本地区故事', chronology:'地区纪年', places:'地标与势力', relics:'地区遗物', read:'阅读故事' } : { back:'Back to universe', stories:'Stories of this region', chronology:'Regional chronology', places:'Places & factions', relics:'Regional relics', read:'Read story' };
---
<main class={`culture-world-v3 world-${chamber.tone}`}>
  <header class="world-v3-hero"><img src={`${base}${stories[0]?.image}`} alt="" /><div class="world-v3-shade"></div><a href={path('/culture')}>← {t.back}</a><div><p class="dc-kicker">REGION {chamber.number}</p><span class="world-glyph">{chamber.glyph}</span><h1>{c.name}</h1><h2>{c.epithet}</h2><p>{c.intro}</p></div></header>
  <nav class="world-v3-nav"><a href="#stories">{t.stories}</a><a href="#chronology">{t.chronology}</a><a href="#places">{t.places}</a><a href="#relics">{t.relics}</a></nav>
  <section class="world-v3-legend"><p class="dc-kicker">THE PRESENT CONFLICT</p><blockquote>{c.legend}</blockquote></section>
  <section class="world-v3-stories" id="stories"><div class="dc-section-head"><div><p class="dc-kicker">FICTION</p><h2>{t.stories}</h2></div></div><div>{stories.map((story,index) => <a href={path(`/culture/stories/${story.slug}`)}><img src={`${base}${story.image}`} alt="" /><span>0{index + 1} · {story.readTime} MIN</span><h3>{locale === 'zh' ? story.titleZh : story.titleEn}</h3><p>{locale === 'zh' ? story.dekZh : story.dekEn}</p><i>{t.read} →</i></a>)}</div></section>
  <section class="world-v3-chronology" id="chronology"><div><p class="dc-kicker">TIMELINE</p><h2>{t.chronology}</h2></div><ol>{c.timeline.map((event) => <li><span>{event.date}</span><div><h3>{event.title}</h3><p>{event.text}</p></div></li>)}</ol></section>
  <section class="world-v3-places" id="places"><div class="dc-section-head"><div><p class="dc-kicker">ATLAS & FACTIONS</p><h2>{t.places}</h2></div></div><div class="world-lore-grid">{c.landmarks.map((item,index) => <article><span>0{index + 1}</span><small>LANDMARK</small><h3>{item.name}</h3><p>{item.text}</p></article>)}{c.factions.map((item,index) => <article><span>0{index + 4}</span><small>FACTION</small><h3>{item.name}</h3><p>{item.text}</p></article>)}</div></section>
  <section class="world-v3-relics" id="relics"><div class="dc-section-head"><div><p class="dc-kicker">OBJECT ARCHIVE</p><h2>{c.productTitle}</h2></div><a href={path('/catalog')}>{t.relics} →</a></div><div>{related.map((product) => product && <a href={path(`/catalog#${product.category}`)}><img src={`${base}${product.image}`} alt={locale === 'zh' ? product.nameZh : product.nameEn} /><span>{product.sku}</span><h3>{locale === 'zh' ? product.nameZh : product.nameEn}</h3></a>)}</div></section>
</main>
