---
import { copy, localePath, site, type Locale } from '../lib/site';
import ThemeToggle from './ThemeToggle.astro';
const { locale = 'zh' } = Astro.props as { locale?: Locale };
const t = copy[locale];
const base = import.meta.env.BASE_URL;
const href = (path = '') => `${base.replace(/\/$/, '')}${localePath(locale, path)}` || '/';
const otherLocale = locale === 'zh' ? 'en' : 'zh';
---
<header class="site-header">
  <a class="brand" href={href()} aria-label="DARK CASTLE home">DARK <span>CASTLE</span></a>
  <nav aria-label="Primary navigation">
    <a href={href()}>{t.nav.home}</a>
    <a href={href('/catalog')}>{t.nav.catalog}</a>
    <a href={href('/#contact')}>{t.nav.contact}</a>
  </nav>
  <div class="header-actions">
    <a class="language" href={`${base.replace(/\/$/, '')}${localePath(otherLocale)}?from=${locale}`} lang={otherLocale}>{otherLocale === 'zh' ? '中' : 'EN'}</a>
    <ThemeToggle label={t.theme} />
  </div>
</header>
