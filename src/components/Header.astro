---
import { copy, localePath, type Locale } from '../lib/site';
import ThemeToggle from './ThemeToggle.astro';
const { locale = 'zh' } = Astro.props as { locale?: Locale }; const t = copy[locale]; const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = (path = '') => `${base}${localePath(locale, path)}` || '/'; const otherLocale = locale === 'zh' ? 'en' : 'zh'; const current = Astro.url.pathname;
const links = locale === 'zh' ? [
  [href(), '宇宙', 'UNIVERSE'], [href('/culture'), '地区', 'REGIONS'], [href('/culture#stories'), '故事', 'STORIES'], [href('/catalog'), '遗物', 'RELICS']
] : [
  [href(), 'Universe', 'HOME'], [href('/culture'), 'Regions', 'ATLAS'], [href('/culture#stories'), 'Stories', 'FICTION'], [href('/catalog'), 'Relics', 'OBJECTS']
];
---
<header class="site-header dc-header-v3">
  <a class="brand" href={href()} aria-label="DARK CASTLE home"><i>DC</i><b>DARK <span>CASTLE</span></b><small>ORIGINAL UNIVERSE</small></a>
  <nav aria-label="Primary navigation">{links.map(([url,label,sub]) => <a class:list={{ 'is-active': url !== href() ? current.includes(url.replace(base,'')) : current === `${base}/` }} href={url}><span>{label}</span><small>{sub}</small></a>)}</nav>
  <div class="header-actions"><a class="language" href={`${base}${localePath(otherLocale)}?from=${locale}`} lang={otherLocale}>{otherLocale === 'zh' ? '中' : 'EN'}</a><a class="dc-mail" href={href('/#contact')}>{t.nav.contact}</a><ThemeToggle label={t.theme} /></div>
</header>
