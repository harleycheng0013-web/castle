---
import { chambers, universeEpoch, type CultureLocale } from '../lib/culture';
import { universeStories } from '../lib/stories';
import { universeCharacters, portraitForCharacter } from '../lib/characters';
const { locale = 'zh' } = Astro.props as { locale?: CultureLocale };
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); const lang = locale === 'en' ? '/en' : '';
const href = (value: string) => `${base}${lang}${value}`;
const t = locale === 'zh' ? {
  title:'文化宇宙', intro:'四境、人物、纪年与故事共同组成 DARK CASTLE 的原创世界。这里没有现实历史的复述，也没有规定的阅读顺序。',
  regions:'选择地区', regionText:'沿着四条道路进入世界，也可以直接从下方故事开始。', stories:'故事档案',
  storyText:'八篇完整故事已经开放。按地区筛选，或搜索人物、标题与时代。', read:'阅读全文', search:'搜索故事或人物', clear:'清除', results:'篇故事',
  people:'人物档案', peopleText:'人物是穿越宇宙的另一条路线。选择一个名字，进入他的出场故事。',
  chronology:'暮辉纪 427 年', chronologyText:'四个遥远地区在同一天发生异常事件，所有线索最终指向中央的黑城堡。',
  original:'原创声明', originalText:'DARK CASTLE 的四境、人物、纪年与故事均为本站原创虚构。现实商品与商业内容现已从宇宙叙事中分离。'
} : {
  title:'Cultural Universe', intro:'Four realms, characters, chronologies, and stories form the original world of DARK CASTLE. There is no required reading order.',
  regions:'Choose a region', regionText:'Follow one of four roads, or begin with any story below.', stories:'Story archive',
  storyText:'Eight complete stories are open. Filter by region or search titles, people, and eras.', read:'Read full story', search:'Search stories or people', clear:'Clear', results:'stories',
  people:'Character dossiers', peopleText:'Characters offer another route through the universe. Choose a name and enter their story.',
  chronology:'Gloaming 427', chronologyText:'Four distant realms suffer anomalies on the same day. Every clue points toward the central Dark Castle.',
  original:'Original fiction notice', originalText:'The realms, characters, chronology, and fiction of DARK CASTLE are original to this site. Commercial content is now separated from the narrative universe.'
};
---
<main class="culture-index-v3">
  <header class="culture-index-hero"><img src={`${base}/images/dark-castle-atlas-v1.png`} alt="" /><div><p class="dc-kicker">DARK CASTLE · ORIGINAL UNIVERSE · VOLUME I</p><h1>{t.title}</h1><p>{t.intro}</p><span>{universeEpoch[locale]}</span></div></header>

  <section class="culture-region-browser" id="regions"><div class="dc-section-head"><div><p class="dc-kicker">REGIONS</p><h2>{t.regions}</h2></div><p>{t.regionText}</p></div><div>{chambers.map((chamber) => <a class={`realm-${chamber.tone}`} href={href(`/culture/${chamber.slug}`)}><span>{chamber.glyph}</span><small>REGION {chamber.number}</small><h3>{chamber[locale].name}</h3><p>{chamber[locale].epithet}</p><i>EXPLORE →</i></a>)}</div></section>

  <section class="culture-story-index" id="stories"><div class="dc-section-head"><div><p class="dc-kicker">ALL FICTION</p><h2>{t.stories}</h2></div><p>{t.storyText}</p></div><div class="story-search-row"><label><span class="sr-only">{t.search}</span><input type="search" data-story-search placeholder={t.search} /></label><span><b data-story-count>{universeStories.length}</b> {t.results}</span><button type="button" data-story-clear>{t.clear}</button></div><div class="culture-story-filter" role="group"><button class="is-active" data-story-filter="all">ALL · {universeStories.length}</button>{chambers.map((chamber) => <button data-story-filter={chamber.slug}>{chamber[locale].name}</button>)}</div><div class="culture-story-list">{universeStories.map((story,index) => {const storyCharacters=universeCharacters.filter((person)=>person.storySlugs.includes(story.slug));const searchText=[story.titleZh,story.titleEn,story.dekZh,story.dekEn,story.eraZh,story.eraEn,...storyCharacters.flatMap((p)=>[p.nameZh,p.nameEn])].join(' ').toLowerCase();return <a href={href(`/culture/stories/${story.slug}`)} data-story-card data-story-chamber={story.chamber} data-story-search-text={searchText}><div class="culture-story-thumb"><img src={`${base}${story.image}`} alt="" loading="lazy" decoding="async" /><span>0{index + 1}</span></div><div><p>{locale === 'zh' ? story.categoryZh : story.categoryEn} · {story.readTime} MIN</p><h3>{locale === 'zh' ? story.titleZh : story.titleEn}</h3><span>{locale === 'zh' ? story.dekZh : story.dekEn}</span><small>{storyCharacters.map((p)=>locale==='zh'?p.nameZh:p.nameEn).join(' · ')}</small><i>{t.read} →</i></div></a>})}</div><p class="story-empty" data-story-empty hidden>{locale === 'zh' ? '没有找到符合条件的故事。' : 'No matching stories found.'}</p></section>

  <section class="character-index" id="characters"><div class="dc-section-head"><div><p class="dc-kicker">CHARACTER DOSSIERS</p><h2>{t.people}</h2></div><p>{t.peopleText}</p></div><div>{universeCharacters.map((person,index) => {const firstStory=universeStories.find((story)=>story.slug===person.storySlugs[0]);const realm=chambers.find((chamber)=>chamber.slug===person.chamber);const portrait=portraitForCharacter(person.id,person.portrait);return <a href={firstStory ? href(`/culture/stories/${firstStory.slug}`) : '#'} class={`character-${realm?.tone}`}>{portrait?<img src={`${base}${portrait}`} alt={locale==='zh'?`${person.nameZh}人物肖像`:`Portrait of ${person.nameEn}`} loading="lazy" decoding="async" />:<span>{person.glyph}</span>}<small>FILE {String(index+1).padStart(2,'0')} · {realm?.[locale].name}</small><h3>{locale==='zh'?person.nameZh:person.nameEn}</h3><strong>{locale==='zh'?person.roleZh:person.roleEn}</strong><p>{locale==='zh'?person.bioZh:person.bioEn}</p><i>{person.storySlugs.length} {locale==='zh'?'篇出场故事':'APPEARANCES'} →</i></a>})}</div></section>

  <section class="master-chronology" id="chronology"><div><p class="dc-kicker">MASTER CHRONICLE</p><h2>{t.chronology}</h2><p>{t.chronologyText}</p></div><ol>{chambers.map((chamber,index)=>{const event=chamber[locale].timeline[chamber[locale].timeline.length-1];return <li><span>0{index+1}</span><small>{chamber[locale].name}</small><h3>{event.title}</h3><p>{event.text}</p><a href={href(`/culture/${chamber.slug}#chronology`)}>{locale==='zh'?'查看地区纪年':'View regional chronology'} →</a></li>})}</ol></section>

  <section class="universe-original-note"><p class="dc-kicker">{t.original}</p><h2>{t.originalText}</h2><span>DARK CASTLE UNIVERSE · VOLUME I · REVISION 2026.07</span></section>
</main>
<script>
  const filterButtons=document.querySelectorAll<HTMLButtonElement>('[data-story-filter]');const cards=[...document.querySelectorAll<HTMLElement>('[data-story-card]')];const search=document.querySelector<HTMLInputElement>('[data-story-search]');const count=document.querySelector<HTMLElement>('[data-story-count]');const empty=document.querySelector<HTMLElement>('[data-story-empty]');let active=sessionStorage.getItem('dc-story-filter')||'all';
  const update=()=>{const query=search?.value.trim().toLowerCase()||'';let visible=0;cards.forEach((card)=>{const show=(active==='all'||card.dataset.storyChamber===active)&&(!query||card.dataset.storySearchText?.includes(query));card.hidden=!show;if(show)visible++});if(count)count.textContent=String(visible);if(empty)empty.hidden=visible!==0;filterButtons.forEach((b)=>b.classList.toggle('is-active',b.dataset.storyFilter===active));sessionStorage.setItem('dc-story-filter',active)};
  filterButtons.forEach((button)=>button.addEventListener('click',()=>{active=button.dataset.storyFilter||'all';update()}));search?.addEventListener('input',update);document.querySelector('[data-story-clear]')?.addEventListener('click',()=>{active='all';if(search)search.value='';update()});update();
</script>
