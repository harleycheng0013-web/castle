---
import { chambers, universeEpoch, type CultureLocale } from '../lib/culture';
import { universeStories } from '../lib/stories';
const { locale = 'zh' } = Astro.props as { locale?: CultureLocale };
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); const lang = locale === 'en' ? '/en' : '';
const href = (value: string) => `${base}${lang}${value}`;
const t = locale === 'zh' ? { title:'文化宇宙', intro:'这里没有现实历史的复述。四境、人物、纪年与故事共同组成 DARK CASTLE 的原创世界。', atlas:'选择地区', atlasText:'沿着四条道路进入世界，也可以直接从下方故事开始。', stories:'故事档案', storyText:'八篇长故事已经开放。每一个结尾都会带你进入下一篇故事、相关地区或对应遗物。', read:'阅读全文' } : { title:'Cultural Universe', intro:'Not a retelling of real history. Four realms, characters, chronologies, and stories form the original world of DARK CASTLE.', atlas:'Choose a region', atlasText:'Follow one of four roads, or begin with any story below.', stories:'Story archive', storyText:'Eight complete stories are open. Every ending leads toward another story, region, or relic.', read:'Read full story' };
---
<main class="culture-index-v3">
  <header class="culture-index-hero"><img src={`${base}/images/dark-castle-hero-atmosphere.png`} alt="" /><div><p class="dc-kicker">DARK CASTLE · ORIGINAL UNIVERSE</p><h1>{t.title}</h1><p>{t.intro}</p><span>{universeEpoch[locale]}</span></div></header>
  <section class="culture-region-browser"><div class="dc-section-head"><div><p class="dc-kicker">REGIONS</p><h2>{t.atlas}</h2></div><p>{t.atlasText}</p></div><div>{chambers.map((chamber) => <a class={`realm-${chamber.tone}`} href={href(`/culture/${chamber.slug}`)}><span>{chamber.glyph}</span><small>REGION {chamber.number}</small><h3>{chamber[locale].name}</h3><p>{chamber[locale].epithet}</p><i>EXPLORE →</i></a>)}</div></section>
  <section class="culture-story-index"><div class="dc-section-head"><div><p class="dc-kicker">ALL FICTION</p><h2>{t.stories}</h2></div><p>{t.storyText}</p></div><div class="culture-story-filter" role="group"><button class="is-active" data-filter="all">ALL · {universeStories.length}</button>{chambers.map((chamber) => <button data-filter={chamber.slug}>{chamber[locale].name}</button>)}</div><div class="culture-story-list">{universeStories.map((story,index) => <a href={href(`/culture/stories/${story.slug}`)} data-story-chamber={story.chamber}><div class="culture-story-thumb"><img src={`${base}${story.image}`} alt="" /><span>0{index + 1}</span></div><div><p>{locale === 'zh' ? story.categoryZh : story.categoryEn} · {story.readTime} MIN</p><h3>{locale === 'zh' ? story.titleZh : story.titleEn}</h3><span>{locale === 'zh' ? story.dekZh : story.dekEn}</span><i>{t.read} →</i></div></a>)}</div></section>
</main>
<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filter]'); const stories = document.querySelectorAll<HTMLElement>('[data-story-chamber]');
  buttons.forEach((button) => button.addEventListener('click', () => { buttons.forEach((item) => item.classList.toggle('is-active', item === button)); const filter = button.dataset.filter; stories.forEach((story) => story.hidden = filter !== 'all' && story.dataset.storyChamber !== filter); }));
</script>
