---
import BaseLayout from '../layouts/BaseLayout.astro';
import { copy, site } from '../lib/site';
import { chambers } from '../lib/culture';
import { products } from '../lib/products';
const t = copy.zh;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const picture = (name: string) => `${base}/images/products/${name}`;
const featured = products.filter((product) => ['DC-006', 'DC-008', 'DC-009'].includes(product.sku));
---
<BaseLayout title={`${site.name} | ${site.role}`} description={site.description}>
  <section class="cinematic-hero">
    <img class="cinematic-backdrop" src={`${base}/images/dark-castle-hero-atmosphere.png`} alt="" aria-hidden="true" />
    <div class="hero-grain"></div><div class="hero-sigil" aria-hidden="true"></div>
    <div class="cinematic-copy"><p class="eyebrow">DARK FANTASY RESIN DÉCOR · EST. 2026</p><p class="hero-kicker">ENTER THE COLLECTION</p><h1>让暗影，<br /><em>成为你的陈设。</em></h1><p>献给收藏者、造景师与相信物件自有故事的人。DARK CASTLE™ 将神话、哥特与秘仪化作可被带回家的树脂艺术。</p><div class="hero-actions"><a class="button button-light" href={`${base}/catalog`}>进入藏品目录</a><a class="text-button" href="#atelier">探索工艺与系列 ↓</a></div></div>
    <div class="hero-relic"><div class="relic-frame"><img src={picture('winged-angel-front.jpg')} alt="黑金翼天使茶烛台" /><span>DC–006 / WINGED ANGEL</span></div></div>
    <div class="hero-caption"><span>01</span><p>Objects with a story<br />made for the curious.</p></div>
  </section>
  <section id="atelier" class="atelier-intro"><div><p class="eyebrow">THE DARK CASTLE ATELIER</p><h2>不是普通摆件，<br />而是<strong>一件可收藏的世界观。</strong></h2></div><div class="atelier-copy"><p>每个作品从一个可辨认的符号出发：森林守护者、翼骨、旧日支配者、羊角与玫瑰。你看到的是摆件，也是一段等待被摆放的叙事。</p><div class="atelier-stats"><span><b>13</b>现有系列</span><span><b>34</b>真实产品图</span><span><b>04</b>清晰主题馆</span></div></div></section>
  <section class="relic-feature"><div class="relic-feature-image"><img src={picture('witch-hands-crystal.jpg')} alt="女巫之手水晶球座" /></div><div class="relic-feature-copy"><p class="eyebrow">THE FEATURED RELIC / DC–013</p><h2>握住一颗<br /><em>未知的星球。</em></h2><p>女巫之手系列可作书挡、水晶球座与陈列托盘。黑色指甲、青铜饰带与骨纹底座，让每一个角落都有进入仪式的理由。</p><a class="button" href={`${base}/catalog#occult`}>探索秘仪陈设</a></div></section>
  <section class="curated-section"><div class="section-lead"><p class="eyebrow">CURATED FOR THE CURIOUS</p><h2>三件值得先带回家的暗影。</h2><a href={`${base}/catalog`}>全部商品目录 →</a></div><div class="curated-grid">{featured.map((product, index) => <a class={`curated-card curated-${index + 1}`} href={`${base}/catalog#${product.category}`}><img src={`${base}${product.image}`} alt={product.nameZh} /><div><p>{product.sku}</p><h3>{product.nameZh}</h3><span>{product.nameEn} →</span></div></a>)}</div></section>
  <section class="collection-doors"><div class="doors-heading"><p class="eyebrow">ENTER THE CULTURAL UNIVERSE</p><h2>从哪一扇门进入？</h2></div><p class="doors-intro">先进入一段文化故事、原典与传说，再遇见由它启发的藏品。</p><div class="doors-grid">{chambers.map((chamber) => <a href={`${base}/culture/${chamber.slug}`} class={`door door-${chamber.tone}`}><span>{chamber.number}</span><h3>{chamber.zh.doorTitle}</h3><p>{chamber.zh.subtitle}</p><i>进入文化宇宙 →</i></a>)}</div></section>
  <section id="contact" class="home-contact"><p class="eyebrow">WHOLESALE / CUSTOM / COLLABORATION</p><h2>为你的店铺，<br />开启另一道门。</h2><p>面向独立零售、主题礼品、空间陈列与小批量定制。告诉我们想要的系列、数量与目的地。</p><a class="button button-light" href={`mailto:${site.email}`}>联系 DARK CASTLE</a><span>{site.email}</span></section>
</BaseLayout>
