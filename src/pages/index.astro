---
import BaseLayout from '../layouts/BaseLayout.astro';
import { collections, copy, site } from '../lib/site';
const t = copy.zh;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title={`${site.name} | ${site.role}`} description={site.description}>
  <section class="store-hero">
    <img class="store-hero-image" src={`${base}/images/dark-castle-hero.png`} alt="暗黑奇幻风格树脂摆件陈列" />
    <div class="store-hero-copy">
      <p class="eyebrow">{t.heroEyebrow}</p>
      <h1>{t.heroTitle.split('\n').map((line) => <>{line}<br /></>)}</h1>
      <p class="lede">{t.heroText}</p>
      <div class="hero-actions"><a class="button" href="#catalog">{t.primaryCta}</a><a class="text-button" href="#contact">{t.secondaryCta} →</a></div>
    </div>
  </section>
  <section id="catalog" class="catalog-section">
    <div class="catalog-heading"><p class="eyebrow">{t.collectionEyebrow}</p><h2>{t.collectionTitle}</h2><p>{t.collectionText}</p></div>
    <div class="collection-grid">{collections.map((collection, index) => <article id={collection.key} class={`collection-card card-${index + 1}`}><p>0{index + 1}</p><h3>{collection.zh}</h3><span>{collection.en}</span><div class="collection-card-bottom"><small>{collection.descriptionZh}</small><a href={`${base}/catalog#${collection.key}`} aria-label={`查看${collection.zh}商品`}>{t.catalogButton} →</a></div></article>)}</div>
  </section>
  <section class="retail-proof"><div><p class="eyebrow">{t.whyEyebrow}</p><h2>{t.whyTitle}</h2></div><ul>{t.points.map((point, index) => <li><span>0{index + 1}</span>{point}</li>)}</ul></section>
  <section id="contact" class="contact store-contact"><p class="eyebrow">WHOLESALE / CUSTOM</p><h2>{t.contactTitle}</h2><p>{t.contactText}</p><a class="email" href={`mailto:${site.email}`}>{site.email}</a><p class="contact-note">商品页可直接发起邮件询盘；WhatsApp 将在你提供号码后加入。</p></section>
</BaseLayout>
