---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collections, copy, site } from '../../lib/site';
const t = copy.en;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title={`${site.name} | ${site.role}`} description={site.description} locale="en">
  <section class="store-hero">
    <img class="store-hero-image" src={`${base}/images/dark-castle-hero.png`} alt="Dark fantasy resin décor display" />
    <div class="store-hero-copy"><p class="eyebrow">{t.heroEyebrow}</p><h1>{t.heroTitle.split('\n').map((line) => <>{line}<br /></>)}</h1><p class="lede">{t.heroText}</p><div class="hero-actions"><a class="button" href="#catalog">{t.primaryCta}</a><a class="text-button" href="#contact">{t.secondaryCta} →</a></div></div>
  </section>
  <section id="catalog" class="catalog-section"><div class="catalog-heading"><p class="eyebrow">{t.collectionEyebrow}</p><h2>{t.collectionTitle}</h2><p>{t.collectionText}</p></div><div class="collection-grid">{collections.map((collection, index) => <article id={collection.key} class={`collection-card card-${index + 1}`}><p>0{index + 1}</p><h3>{collection.en}</h3><span>{collection.zh}</span><div class="collection-card-bottom"><small>{collection.descriptionEn}</small><a href={`${base}/en/catalog#${collection.key}`} aria-label={`Browse ${collection.en}`}>{t.catalogButton} →</a></div></article>)}</div></section>
  <section class="retail-proof"><div><p class="eyebrow">{t.whyEyebrow}</p><h2>{t.whyTitle}</h2></div><ul>{t.points.map((point, index) => <li><span>0{index + 1}</span>{point}</li>)}</ul></section>
  <section id="contact" class="contact store-contact"><p class="eyebrow">WHOLESALE / CUSTOM</p><h2>{t.contactTitle}</h2><p>{t.contactText}</p><a class="email" href={`mailto:${site.email}`}>{site.email}</a><p class="contact-note">This email is a placeholder. Replace it with your business email and WhatsApp in <code>src/lib/site.ts</code>.</p></section>
</BaseLayout>
