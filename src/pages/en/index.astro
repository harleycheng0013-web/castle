---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../lib/site';
import { chambers } from '../../lib/culture';
import { products } from '../../lib/products';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const picture = (name: string) => `${base}/images/products/${name}`;
const featured = products.filter((product) => ['DC-006', 'DC-008', 'DC-009'].includes(product.sku));
---
<BaseLayout title={`${site.name} | ${site.role}`} description={site.description} locale="en">
  <section class="cinematic-hero"><img class="cinematic-backdrop" src={`${base}/images/dark-castle-hero-atmosphere.png`} alt="" aria-hidden="true" /><div class="hero-grain"></div><div class="hero-sigil" aria-hidden="true"></div><div class="cinematic-copy"><p class="eyebrow">DARK FANTASY RESIN DÉCOR · EST. 2026</p><p class="hero-kicker">ENTER THE COLLECTION</p><h1>Let shadow<br /><em>be part of your space.</em></h1><p>For collectors, set designers, and anyone who believes an object can carry a story. DARK CASTLE™ turns mythology, gothic form, and ritual into resin art made to live with you.</p><div class="hero-actions"><a class="button button-light" href={`${base}/en/catalog`}>Enter the collection</a><a class="text-button" href="#atelier">Explore the atelier ↓</a></div></div><div class="hero-relic"><div class="relic-frame"><img src={picture('winged-angel-front.jpg')} alt="Black and gold winged angel holder" /><span>DC–006 / WINGED ANGEL</span></div></div><div class="hero-caption"><span>01</span><p>Objects with a story<br />made for the curious.</p></div></section>
  <section id="atelier" class="atelier-intro"><div><p class="eyebrow">THE DARK CASTLE ATELIER</p><h2>Not ordinary décor—<br /><strong>a world to collect.</strong></h2></div><div class="atelier-copy"><p>Every piece begins with a recognizable symbol: a forest guardian, bone wings, an elder god, a ram's horn, a rose. What you see is décor; what you bring home is a waiting story.</p><div class="atelier-stats"><span><b>13</b> current collections</span><span><b>34</b> real product images</span><span><b>04</b> defined chambers</span></div></div></section>
  <section class="relic-feature"><div class="relic-feature-image"><img src={picture('witch-hands-crystal.jpg')} alt="Witch hands crystal holder" /></div><div class="relic-feature-copy"><p class="eyebrow">THE FEATURED RELIC / DC–013</p><h2>Hold a piece<br /><em>of the unknown.</em></h2><p>The Witch Hands series becomes a bookend, crystal-ball holder, or display tray. Black nails, antique-gold bands, and a bone-detailed base make a ritual out of an ordinary corner.</p><a class="button" href={`${base}/en/catalog#occult`}>Explore ritual objects</a></div></section>
  <section class="curated-section"><div class="section-lead"><p class="eyebrow">CURATED FOR THE CURIOUS</p><h2>Three shadows to bring home first.</h2><a href={`${base}/en/catalog`}>View full catalog →</a></div><div class="curated-grid">{featured.map((product, index) => <a class={`curated-card curated-${index + 1}`} href={`${base}/en/catalog#${product.category}`}><img src={`${base}${product.image}`} alt={product.nameEn} /><div><p>{product.sku}</p><h3>{product.nameEn}</h3><span>{product.nameZh} →</span></div></a>)}</div></section>
  <section class="collection-doors"><div class="doors-heading"><p class="eyebrow">ENTER THE CULTURAL UNIVERSE</p><h2>Which door will you open?</h2></div><p class="doors-intro">Enter a cultural story, source text, and legend first—then meet the objects it inspires.</p><div class="doors-grid">{chambers.map((chamber) => <a href={`${base}/en/culture/${chamber.slug}`} class={`door door-${chamber.tone}`}><span>{chamber.number}</span><h3>{chamber.en.doorTitle}</h3><p>{chamber.en.subtitle}</p><i>Enter the universe →</i></a>)}</div></section>
  <section id="contact" class="home-contact"><p class="eyebrow">WHOLESALE / CUSTOM / COLLABORATION</p><h2>Open another door<br />for your store.</h2><p>For independent retail, themed gifting, spatial displays, and small-batch custom work. Tell us the collection, quantity, and destination.</p><a class="button button-light" href={`mailto:${site.email}`}>Contact DARK CASTLE</a><span>{site.email}</span></section>
</BaseLayout>
